# === Authentication (choose one method) ===

# Method 1: OAuth2 (for personal accounts or interactive use)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Method 2: Service Account (for GWS with domain-wide delegation)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json
# GOOGLE_IMPERSONATE_USER=user@company.com  # Optional: impersonate a GWS user

# === Options ===
GOOGLE_DRIVE_ALLOW_WRITE=false
# GOOGLE_DRIVE_SCOPES=drive.readonly  # Comma-separated. Default: drive.readonly
